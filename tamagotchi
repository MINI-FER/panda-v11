<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Panda Virtual 🐼</title>
    <style>
        :root {
            --bg-color: #fce4ec;
            --case-color: #ff80ab;
            --screen-color: #e0f2f1;
            --pixel-color: #333;
        }

        body {
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: 'Courier New', Courier, monospace;
            overflow: hidden;
            touch-action: manipulation;
        }

        /* Carcasa del Tamagotchi */
        .tamagotchi-case {
            width: 320px;
            height: 420px;
            background: var(--case-color);
            border-radius: 50% 50% 45% 45% / 40% 40% 60% 60%;
            position: relative;
            box-shadow: inset -10px -10px 20px rgba(0,0,0,0.2), 0 20px 40px rgba(0,0,0,0.3);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 40px;
            border: 8px solid #f06292;
        }

        /* Pantalla */
        .screen {
            width: 200px;
            height: 160px;
            background: var(--screen-color);
            border: 10px solid #880e4f;
            border-radius: 10px;
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            box-shadow: inset 0 0 15px rgba(0,0,0,0.1);
        }

        /* El Panda */
        .panda {
            font-size: 80px;
            transition: all 0.3s;
            position: relative;
            z-index: 2;
        }

        .bounce { animation: bounce 1s infinite; }
        .sleep { filter: grayscale(1) opacity(0.7); transform: rotate(20deg); }
        .dead { transform: rotate(180deg); }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        /* Barras de Estado */
        .stats {
            width: 80%;
            margin-top: 20px;
            color: #880e4f;
            font-weight: bold;
            font-size: 12px;
        }

        .stat-bar {
            width: 100%;
            height: 12px;
            background: #fff;
            border-radius: 6px;
            margin: 5px 0 10px 0;
            overflow: hidden;
            border: 2px solid #880e4f;
        }

        .fill {
            height: 100%;
            background: #ff4081;
            transition: width 0.5s;
        }

        /* Botones */
        .buttons-container {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }

        .btn {
            width: 60px;
            height: 60px;
            background: #f48fb1;
            border: none;
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 4px #c2185b;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            font-size: 20px;
            transition: 0.1s;
        }

        .btn:active {
            box-shadow: 0 0 #c2185b;
            transform: translateY(4px);
        }

        .btn-label {
            font-size: 8px;
            margin-top: 5px;
            font-weight: bold;
            text-transform: uppercase;
        }

        /* Notificaciones flotantes */
        .float-text {
            position: absolute;
            animation: floatUp 1s forwards;
            font-weight: bold;
            color: #c2185b;
            pointer-events: none;
        }

        @keyframes floatUp {
            from { opacity: 1; transform: translateY(0); }
            to { opacity: 0; transform: translateY(-50px); }
        }

        .level-badge {
            position: absolute;
            top: 5px;
            right: 5px;
            background: #880e4f;
            color: white;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 10px;
        }

        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            color: white;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            z-index: 10;
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div class="tamagotchi-case">
        <div class="screen" id="main-screen">
            <div class="level-badge" id="level-txt">LVL 1</div>
            <div class="panda bounce" id="panda">🐼</div>
            <div id="overlay" class="overlay">
                <p>Oh no...<br>Tu panda se fue a dormir por cansancio.</p>
                <button onclick="resetGame()" style="padding: 5px 10px;">Revivir</button>
            </div>
        </div>

        <div class="stats">
            HAMBRE
            <div class="stat-bar"><div id="hunger-bar" class="fill" style="width: 100%;"></div></div>
            FELICIDAD
            <div class="stat-bar"><div id="happy-bar" class="fill" style="width: 100%;"></div></div>
            ENERGÍA
            <div class="stat-bar"><div id="energy-bar" class="fill" style="width: 100%;"></div></div>
        </div>

        <div class="buttons-container">
            <button class="btn" onclick="feed()">
                🍎
                <span class="btn-label">Comer</span>
            </button>
            <button class="btn" onclick="play()">
                🎾
                <span class="btn-label">Jugar</span>
            </button>
            <button class="btn" onclick="sleep()">
                💤
                <span class="btn-label">Dormir</span>
            </button>
        </div>
        
        <p style="font-size: 10px; margin-top: 20px; color: #880e4f;">¡Cuídalo mucho, amorchito!</p>
    </div>

    <script>
        let hunger = 100;
        let happiness = 100;
        let energy = 100;
        let level = 1;
        let exp = 0;
        let isSleeping = false;
        let isDead = false;

        const panda = document.getElementById('panda');
        const overlay = document.getElementById('overlay');

        // Ciclo de vida: Los stats bajan cada 3 segundos
        const gameLoop = setInterval(() => {
            if (!isSleeping && !isDead) {
                updateStats(-3, -2, -1);
                checkStatus();
            }
        }, 3000);

        function updateStats(h, ha, e) {
            hunger = Math.min(100, Math.max(0, hunger + h));
            happiness = Math.min(100, Math.max(0, happiness + ha));
            energy = Math.min(100, Math.max(0, energy + e));
            
            document.getElementById('hunger-bar').style.width = hunger + '%';
            document.getElementById('happy-bar').style.width = happiness + '%';
            document.getElementById('energy-bar').style.width = energy + '%';

            if(exp >= 100) {
                levelUp();
            }
        }

        function checkStatus() {
            if (hunger <= 0 || happiness <= 0 || energy <= 0) {
                gameOver();
            } else if (hunger < 30 || happiness < 30) {
                panda.innerText = '😟';
            } else if (energy < 30) {
                panda.innerText = '🥱';
            } else {
                panda.innerText = '🐼';
            }
        }

        function feed() {
            if (isSleeping || isDead) return;
            createEffect('🍎 +10');
            updateStats(10, 2, -2);
            gainExp(10);
            panda.innerText = '😋';
            setTimeout(() => checkStatus(), 1000);
        }

        function play() {
            if (isSleeping || isDead) return;
            createEffect('❤️ +15');
            updateStats(-10, 15, -10);
            gainExp(20);
            panda.classList.add('bounce');
            panda.innerText = '😄';
            setTimeout(() => checkStatus(), 1000);
        }

        function sleep() {
            if (isDead) return;
            isSleeping = true;
            panda.innerText = '😴';
            panda.classList.remove('bounce');
            panda.classList.add('sleep');
            
            let sleepTime = setInterval(() => {
                if (energy < 100) {
                    updateStats(0, 0, 10);
                } else {
                    wakeUp();
                    clearInterval(sleepTime);
                }
            }, 1000);
        }

        function wakeUp() {
            isSleeping = false;
            panda.classList.remove('sleep');
            panda.classList.add('bounce');
            checkStatus();
        }

        function gainExp(amount) {
            exp += amount;
        }

        function levelUp() {
            level++;
            exp = 0;
            document.getElementById('level-txt').innerText = 'LVL ' + level;
            createEffect('¡LEVEL UP! ✨');
        }

        function createEffect(text) {
            const el = document.createElement('div');
            el.className = 'float-text';
            el.innerText = text;
            el.style.left = '50%';
            el.style.top = '50%';
            document.getElementById('main-screen').appendChild(el);
            setTimeout(() => el.remove(), 1000);
        }

        function gameOver() {
            isDead = true;
            panda.innerText = '😵';
            panda.classList.add('dead');
            overlay.style.display = 'flex';
        }

        function resetGame() {
            hunger = 100;
            happiness = 100;
            energy = 100;
            isDead = false;
            isSleeping = false;
            panda.innerText = '🐼';
            panda.classList.remove('dead', 'sleep');
            panda.classList.add('bounce');
            overlay.style.display = 'none';
            updateStats(0,0,0);
        }
    </script>
</body>
</html>


